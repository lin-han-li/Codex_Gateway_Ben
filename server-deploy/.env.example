# Server bind
OAUTH_APP_HOST=0.0.0.0
OAUTH_APP_PORT=4777

# Data and web directories. Relative paths are resolved from the deploy root.
OAUTH_APP_DATA_DIR=./data
OAUTH_APP_WEB_DIR=./src/web

# Required for non-loopback bind
OAUTH_APP_ADMIN_TOKEN=replace-with-a-long-random-admin-token
OAUTH_APP_ENCRYPTION_KEY=replace-with-64-hex-chars

# Optional upstream overrides
OAUTH_CODEX_API_BASE=https://chatgpt.com/backend-api/codex
OAUTH_OPENAI_API_BASE=https://api.openai.com/v1
OAUTH_CODEX_ORIGINATOR=codex_cli_rs
# OAUTH_CODEX_CLIENT_VERSION=0.115.0
# OAUTH_CODEX_OFFICIAL_ROOT=/opt/codex-official
# OAUTH_CODEX_PROMPT_FILE=/opt/codex-gateway/custom/prompt.md
# OAUTH_CODEX_MODELS_FILE=/opt/codex-gateway/custom/models.json
# OAUTH_CODEX_ALLOWED_WORKSPACE_ID=

# Forward proxy. Keep disabled unless you explicitly need it.
OAUTH_APP_FORWARD_PROXY_ENABLED=0
OAUTH_APP_FORWARD_PROXY_PORT=4778
OAUTH_APP_FORWARD_PROXY_ALLOWED_HOSTS=api.openai.com,auth.openai.com,ab.chatgpt.com,chatgpt.com,.chatgpt.com,openai.com,.openai.com,oaistatic.com,.oaistatic.com,oaiusercontent.com,.oaiusercontent.com,github.com,.github.com,githubusercontent.com,.githubusercontent.com,githubassets.com,.githubassets.com
OAUTH_APP_FORWARD_PROXY_ENFORCE_ALLOWLIST=1

# Optional
# OAUTH_BOOT_LOG_FILE=./data/bootstrap.log
# OAUTH_DEBUG_ROUTING=0
